{
  "version": 2,
  "builds": [
    { "src": "server.js", "use": "@vercel/node" },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "datos.json", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/", "dest": "/dashboard.html" },
    { "src": "/api/(.*)", "dest": "/server.js" },
    { "src": "/(.*\\.html)", "dest": "/$1" }
  ]
}
